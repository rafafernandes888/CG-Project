<world>
    <window width="512" height="512" />
    <camera> 
	    <position x="3" y="2" z="1" />
	    <lookAt x="0" y="0" z="0" />
	    <up x="0" y="1" z="0" />
        <projection fov="60" near="1" far="1000" /> 
    </camera>
    <group>

        <!-- Box base, centrada na origem -->
        <group>
            <models>
                <model file="box_2_3.3d" />
            </models>
        </group>

        <!-- Cone em cima da box: base em Y=1 (topo da box) -->
        <group>
            <transform>
                <translate x="0" y="1" z="0" />
            </transform>
            <models>
                <model file="cone_1_2_4_3.3d" />
            </models>

            <!-- Box em cima do cone: topo do cone está em Y=2 relativamente ao cone -->
            <group>
                <transform>
                    <translate x="0" y="2" z="0" />
                </transform>
                <models>
                    <model file="box_2_3.3d" />
                </models>
            </group>
        </group>

    </group>
</world>